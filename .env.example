# ── LLM (OpenAI u otro proveedor compatible) ─────────────────────────────────
MOONSHOT_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOONSHOT_BASE_URL=https://api.openai.com/v1
MOONSHOT_MODEL=gpt-4o-mini             # opciones: gpt-4o-mini | gpt-4o | gpt-4-turbo

# ── Evolution API ─────────────────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu-api-key-de-evolution
EVOLUTION_INSTANCE=nombre-de-tu-instancia

# ── PostgreSQL (la misma DB de Evolution API) ─────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/evolution

# ── Comportamiento del agente ─────────────────────────────────────────────────
WEBHOOK_SECRET=                         # opcional: secret para verificar webhooks
HISTORY_LIMIT=15                        # mensajes de contexto por chat
PERSONALITY_SAMPLE=200                  # mensajes propios usados para construir la personalidad
PERSONALITY_TTL=3600                    # segundos antes de reconstruir el perfil (1 hora)
IGNORE_GROUPS=true                      # ignorar mensajes de grupos

PORT=8000
